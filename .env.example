# Basic auth (leave empty to disable)
AUTH_USER=admin
AUTH_PASSWORD=admin

# AI Vuln Generator — LLM configuration
LLM_PROVIDER=openai
LLM_MODEL=openai/gpt-oss-20b
LLM_BASE_URL=http://host.docker.internal:1234/v1
LLM_API_KEY=
LLM_AUTH_KEY=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# BZone Service — BI.ZONE API
BZ_TOKEN=
BZ_BASE_URL=https://bugbounty.bi.zone
BZ_COMPANIES=sber-bugs-zone-vi,sberbank-online,sberbank-site,sberbank-invest,sberbankaktivno,shareholder-sberbank,sber-business,sber-anti-fraud,sberuniversity,sber-iot
BZ_TARGET_STAGES=

# Archive Service — Embedding configuration
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=http://host.docker.internal:1234/v1
EMBEDDING_API_KEY=
EMBEDDING_AUTH_KEY=
EMBEDDING_DIMENSIONS=512
